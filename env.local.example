# ============================================
# SCHOOLIUM ENVIRONMENT VARIABLES
# ============================================
# Get these from your Supabase project:
# supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# SERVER-ONLY (never NEXT_PUBLIC_)
# ============================================

# Service role key - used by API routes only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Alerts BYOG pipeline (chat21)
# Vault key: 32 bytes, hex or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER store this key in Postgres - a DB dump alone must be useless.
ALERTS_VAULT_KEY=generate_a_32_byte_key_here

# Bearer secret pg_cron sends to POST /api/worker
ALERTS_WORKER_SECRET=generate_a_long_random_string_here

# HMAC secret for per-school webhook URL tokens
ALERTS_WEBHOOK_SECRET=generate_another_long_random_string_here

# ============================================
# DO NOT SHARE THIS FILE WITH ANYONE
# This file is already in .gitignore
# ============================================
